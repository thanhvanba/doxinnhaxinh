# Supabase (lấy ở Settings → API trong dashboard Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# CHỈ dùng phía server (API routes / pipeline). KHÔNG bao giờ prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Admin: mật khẩu đăng nhập /admin + salt cho cookie phiên (chuỗi ngẫu nhiên)
ADMIN_PASSWORD=
ADMIN_SESSION_SALT=

# Shopee Affiliate ID — số sau "an_" trong utm_source của link affiliate (vd an_17304340338 → 17304340338).
# Dùng để tự ghép link affiliate bằng công thức an_redir (server-side, không cần API/cookie).
SHOPEE_AFFILIATE_ID=

# AI viết caption — endpoint chuẩn OpenAI (OpenCode Zen / OpenAI / ...)
AI_API_KEY=
AI_BASE_URL=https://opencode.ai/zen/v1
AI_MODEL=minimax-m3-free

# Facebook Graph API (đăng fanpage) — page bạn là admin
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# Telegram bot (ra lệnh đăng bài) — token từ @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_ID=
