# Supabase (lấy ở Settings → API trong dashboard Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# CHỈ dùng phía server (API routes / pipeline). KHÔNG bao giờ prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Admin: mật khẩu đăng nhập /admin + salt cho cookie phiên (chuỗi ngẫu nhiên)
ADMIN_PASSWORD=
ADMIN_SESSION_SALT=

# Shopee Affiliate ID — số sau "an_" trong utm_source của link affiliate (vd an_17304340338 → 17304340338).
# Dùng để tự ghép link affiliate bằng công thức an_redir (server-side, không cần API/cookie).
SHOPEE_AFFILIATE_ID=

# AI viết caption + trợ lý — endpoint chuẩn OpenAI (Google Gemini / OpenCode Zen / ...)
# AI_API_KEYS: nhiều key ngăn cách dấu phẩy → tự nhảy key khi 1 cái hết quota (như 9Router).
AI_API_KEYS=
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_MODEL=gemini-flash-latest
# (tùy chọn) provider dự phòng khi hết sạch key chính:
# AI_FALLBACK_BASE_URL=https://opencode.ai/zen/v1
# AI_FALLBACK_MODEL=mimo-v2.5-free
# AI_FALLBACK_KEY=

# Facebook Graph API (đăng fanpage) — page bạn là admin
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# Telegram bot (ra lệnh đăng bài) — token từ @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_ID=

# Cron — bí mật bảo vệ /api/cron/run (tự đăng bài hẹn giờ + nhắc sáng)
CRON_SECRET=

# Bí mật bảo vệ /api/ingest-media — userscript Tampermonkey lấy ảnh+video Shopee đẩy về DB
MEDIA_INGEST_SECRET=
